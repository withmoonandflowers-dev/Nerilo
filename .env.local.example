# Firebase Configuration
# 複製此檔案為 .env.local 並填入你的 Firebase 專案設定
# .env.local 已被 .gitignore 排除，不會被提交到版本控制

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# TURN Server（NAT 穿透 — symmetric NAT 使用者需要它才能建立 P2P）
# 免費方案：https://dashboard.metered.ca/signup（20GB/月，可鎖定網域防盜用）
# 未設定時退回 STUN-only：多數家用網路可用，嚴格 NAT 使用者會降級到 Firestore relay
# 多個 URL 用逗號分隔
VITE_TURN_URLS=turn:a.relay.metered.ca:80,turn:a.relay.metered.ca:443,turns:a.relay.metered.ca:443?transport=tcp
VITE_TURN_USERNAME=your-metered-username
VITE_TURN_CREDENTIAL=your-metered-credential

# 動態 TURN 憑證 endpoint（可選；需要部署 getIceServers Cloud Function）
# VITE_TURN_CREDENTIAL_ENDPOINT=https://your-region-your-project.cloudfunctions.net/getIceServers
