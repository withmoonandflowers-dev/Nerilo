# Production Firebase Configuration
#
# Copy this to .env.production and fill in the real production credentials.
# .env.production is gitignored — never commit real secrets.
#
# Loaded by Vite when building with `--mode production` (the default for
# `npm run build` and `npm run deploy:production`).

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

VITE_DEPLOY_ENV=production
