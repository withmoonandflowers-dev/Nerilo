# Production Firebase Configuration
#
# Copy this to .env.production and fill in the real production credentials
# from the nerilo Firebase project. .env.production is gitignored.
#
# Loaded by Vite when building with `--mode production` (the default for
# `npm run build` and `npm run deploy:production`).
#
# The deploy script refuses to run if any value still starts with REPLACE_ME_.

VITE_FIREBASE_API_KEY=REPLACE_ME_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=nerilo.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=nerilo
VITE_FIREBASE_STORAGE_BUCKET=nerilo.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=REPLACE_ME_SENDER_ID
VITE_FIREBASE_APP_ID=REPLACE_ME_APP_ID

VITE_DEPLOY_ENV=production

# Sentry DSN for production crash reporting.
VITE_SENTRY_DSN=
