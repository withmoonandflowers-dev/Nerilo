# Staging Firebase Configuration
#
# Copy this to .env.staging and fill in the values for your staging environment.
# .env.staging is gitignored — never commit real secrets.
#
# Loaded by Vite when building with `--mode staging`
# (npm run build:staging / npm run deploy:staging).
#
# Currently staging shares the same Firebase project as production, but uses a
# Hosting preview channel for an isolated URL. When a separate Firebase staging
# project is provisioned, swap these values to point at it.

VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef123456

# Optional: surface a "STAGING" banner / different analytics tag in the UI
VITE_DEPLOY_ENV=staging
