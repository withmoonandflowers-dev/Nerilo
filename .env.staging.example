# Staging Firebase Configuration
#
# Copy this file to .env.staging and fill in the real values from the
# nerilo-staging Firebase project console.
#
# .env.staging is gitignored — never commit real secrets.
# Vite loads this when building with `--mode staging`
# (npm run build:staging / npm run deploy:staging).
#
# ──────────────────────────────────────────────────────────────────────
# Setup checklist (see docs/DEPLOYMENT.md for the full walkthrough):
#   1. In https://console.firebase.google.com, create project "nerilo-staging"
#   2. Add a Web app to that project
#   3. Enable Anonymous auth (Authentication → Sign-in method)
#   4. Enable Firestore (any region; same security rules as prod)
#   5. Copy the 6 VITE_FIREBASE_* values below from the Firebase web-app config
#   6. Replace every "REPLACE_ME_*" placeholder
#   7. Run: npm run deploy:staging
# ──────────────────────────────────────────────────────────────────────
#
# The deploy script refuses to run if any value still starts with REPLACE_ME_.

VITE_FIREBASE_API_KEY=REPLACE_ME_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=REPLACE_ME_PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=nerilo-staging
VITE_FIREBASE_STORAGE_BUCKET=REPLACE_ME_PROJECT.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=REPLACE_ME_SENDER_ID
VITE_FIREBASE_APP_ID=REPLACE_ME_APP_ID

# Mode marker — read by the UI to display a "STAGING" banner / different
# analytics tag. Keep as "staging" for this env file.
VITE_DEPLOY_ENV=staging

# Optional: Sentry error reporting. Get a DSN from https://sentry.io/.
# Leave blank to disable Sentry on staging (recommended only for trusted
# dogfood — beta users should have reporting on).
VITE_SENTRY_DSN=
