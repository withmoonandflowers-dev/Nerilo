# Normalize line endings on commit to LF, regardless of contributor OS.
# This file is the source of truth — core.autocrlf settings should not affect tracked files.

* text=auto eol=lf

# Windows shell scripts must keep CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# Source — explicit LF for unambiguous interop with Node toolchain
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.sh        text eol=lf

# Binary — never touch
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.webp      binary
*.svg       text eol=lf
*.woff      binary
*.woff2     binary
*.ttf       binary
*.eot       binary
*.pdf       binary
*.zip       binary
*.gz        binary

# Lockfiles — let git handle, but force LF
package-lock.json   text eol=lf
yarn.lock           text eol=lf
pnpm-lock.yaml      text eol=lf
