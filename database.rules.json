{
  "rules": {
    "rooms": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".indexOn": ["ownerUid", "status", "isPrivate"],
      "$roomId": {
        "participants": {
          "$uid": {
            ".write": "auth.uid === $uid || root.child('rooms').child($roomId).child('ownerUid').val() === auth.uid"
          }
        }
      }
    },
    "signals": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$roomId": {
        ".indexOn": ["createdAt"],
        "$signalId": {
          ".validate": "newData.hasChildren(['from', 'type', 'payload', 'createdAt'])"
        }
      }
    },
    "relay": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$roomId": {
        ".indexOn": ["to", "expiresAt"]
      }
    },
    "inbox": {
      "$roomId": {
        "$uid": {
          ".read": "auth.uid === $uid",
          ".write": "auth != null",
          ".indexOn": ["expiresAt"]
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth.uid === $uid"
      }
    }
  }
}
