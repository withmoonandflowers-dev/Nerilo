{
  "rules": {
    "rooms": {
      ".read": "auth != null",
      ".indexOn": ["ownerUid", "status", "isPrivate"],
      "$roomId": {
        ".write": "auth != null && (!data.exists() || data.child('ownerUid').val() === auth.uid || data.child('participants').child(auth.uid).exists())",
        ".validate": "newData.hasChildren(['name', 'ownerUid'])",
        "participants": {
          "$uid": {
            ".write": "auth.uid === $uid || root.child('rooms').child($roomId).child('ownerUid').val() === auth.uid"
          }
        }
      }
    },
    "signals": {
      "$roomId": {
        ".read": "auth != null && root.child('rooms').child($roomId).child('participants').child(auth.uid).exists()",
        ".write": "auth != null && root.child('rooms').child($roomId).child('participants').child(auth.uid).exists()",
        ".indexOn": ["createdAt"],
        "$signalId": {
          ".validate": "newData.hasChildren(['from', 'type', 'payload', 'createdAt'])"
        }
      }
    },
    "relay": {
      "$roomId": {
        ".read": "auth != null && root.child('rooms').child($roomId).child('participants').child(auth.uid).exists()",
        ".write": "auth != null && root.child('rooms').child($roomId).child('participants').child(auth.uid).exists()",
        ".indexOn": ["to", "expiresAt"]
      }
    },
    "inbox": {
      "$roomId": {
        "$uid": {
          ".read": "auth.uid === $uid",
          ".write": "auth != null && root.child('rooms').child($roomId).child('participants').child(auth.uid).exists()",
          ".indexOn": ["expiresAt"]
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth.uid === $uid"
      }
    },
    "roomRequests": {
      "$requestId": {
        ".read": "auth != null",
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['type', 'from', 'createdAt'])"
      }
    }
  }
}
