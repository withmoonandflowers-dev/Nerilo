{
  "rules": {
    "rooms": {
      ".read": "auth != null",
      ".indexOn": ["ownerUid", "status", "isPrivate"],
      "$roomId": {
        ".write": "auth != null && !data.exists()",
        ".validate": "newData.hasChildren(['ownerUid', 'status', 'participants']) && newData.child('ownerUid').val() === auth.uid && newData.child('status').val().matches(/^(waiting|open|closed)$/)",
        "ownerUid": {
          ".write": "false"
        },
        "status": {
          ".write": "auth != null && (data.parent().child('ownerUid').val() === auth.uid || data.parent().child('participants').child(auth.uid).exists())",
          ".validate": "newData.val().matches(/^(waiting|open|closed)$/)"
        },
        "participants": {
          ".read": "auth != null && (root.child('rooms').child($roomId).child('isPrivate').val() !== true || root.child('rooms').child($roomId).child('participants').child(auth.uid).exists() || root.child('rooms').child($roomId).child('ownerUid').val() === auth.uid)",
          ".write": "auth != null && (data.parent().child('ownerUid').val() === auth.uid || data.parent().child('participants').child(auth.uid).exists())",
          "$uid": {
            ".write": "auth.uid === $uid || root.child('rooms').child($roomId).child('ownerUid').val() === auth.uid"
          }
        },
        "meshIdentities": {
          ".read": "auth != null && (root.child('rooms').child($roomId).child('isPrivate').val() !== true || root.child('rooms').child($roomId).child('participants').child(auth.uid).exists() || root.child('rooms').child($roomId).child('ownerUid').val() === auth.uid)",
          ".write": "auth != null && data.parent().child('participants').child(auth.uid).exists()"
        },
        "topology": {
          ".write": "auth != null && data.parent().child('participants').child(auth.uid).exists()"
        },
        "closedAt": {
          ".write": "auth != null && data.parent().child('ownerUid').val() === auth.uid"
        },
        "$other": {
          ".write": "auth != null && (data.parent().child('ownerUid').val() === auth.uid || !data.exists())",
          ".validate": "newData.isString() || newData.isNumber() || newData.isBoolean()"
        }
      }
    },
    "signals": {
      "$roomId": {
        ".read": "auth != null && root.child('rooms').child($roomId).child('participants').child(auth.uid).exists()",
        ".write": "auth != null && root.child('rooms').child($roomId).child('participants').child(auth.uid).exists()",
        ".indexOn": ["createdAt"],
        "$signalId": {
          ".validate": "newData.hasChildren(['from', 'type', 'payload', 'createdAt']) && newData.child('from').val() === auth.uid && newData.child('type').val().matches(/^(offer|answer|ice|hello|hello-ack|mesh-offer|mesh-answer|mesh-ice)$/) && newData.child('payload').val().length < 10000"
        }
      }
    },
    "relay": {
      "$roomId": {
        ".read": "auth != null && root.child('rooms').child($roomId).child('participants').child(auth.uid).exists()",
        ".write": "auth != null && root.child('rooms').child($roomId).child('participants').child(auth.uid).exists()",
        ".indexOn": ["to", "expiresAt"]
      }
    },
    "inbox": {
      "$roomId": {
        "$uid": {
          ".read": "auth.uid === $uid",
          ".write": "auth != null && root.child('rooms').child($roomId).child('participants').child(auth.uid).exists()",
          ".indexOn": ["expiresAt"]
        }
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null",
        ".write": "auth.uid === $uid"
      }
    },
    "roomRequests": {
      "$requestId": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() || data.child('from').val() === auth.uid)",
        ".validate": "newData.hasChildren(['type', 'from', 'createdAt']) && newData.child('from').val() === auth.uid"
      }
    }
  }
}
