rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      // 若尚未設定自訂角色（例如匿名使用者），預設視為 guest
      return request.auth.token.role != null ? request.auth.token.role : 'guest';
    }

    function isAdmin() {
      return getUserRole() == 'admin';
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // ── meshIdentities 驗證 ──────────────────────────────────────────────
    function isValidMeshIdentity(identity) {
      return identity.userId is string
        && identity.userId.size() >= 8
        && identity.userId.size() <= 64
        && identity.pubKey is string
        && identity.pubKey.size() >= 40
        && identity.pubKey.size() <= 512;
    }

    // 任何 update 都只能影響到 meshIdentities[auth.uid] 這個 key。
    // 沒有此檢查時，惡意參與者（甚至房主）可以覆寫他人的 ECDH 公鑰，造成 MITM。
    function meshIdentitiesChangeIsValid() {
      let oldMI = resource.data.get('meshIdentities', {});
      let newMI = request.resource.data.get('meshIdentities', {});
      // affectedKeys() 包含新增、修改、刪除的 key。要求 ⊆ {auth.uid}。
      return newMI.diff(oldMI).affectedKeys().hasOnly([request.auth.uid]);
    }

    // Features collection - 功能註冊表
    match /features/{featureId} {
      // 所有人可讀取 enabled=true 的功能
      allow read: if isAuthenticated();

      // 僅 admin 可寫入
      allow write: if isAdmin();
    }

    // Users collection - 使用者 profile
    // 開發階段簡化規則：只要有登入（包含匿名），即可讀寫自己的 users 文件
    match /users/{uid} {
      allow read, create, update: if isAuthenticated() && isOwner(uid);
      allow delete: if false; // 不允許從前端刪除 user 文件
    }

    // ── 房間人數上限（ADR-0005 第一層：結構性總量限制） ──────────────
    // 目前接線的拓撲上限是 5 人 full mesh；6 人以上的 partial mesh 未接線。
    // 方案分層上線後（ADR-0008），此上限改由 request.auth.token.plan 決定。
    function participantsWithinCap(data) {
      return data.participants is list
        && data.participants.size() <= 5;
    }

    // P2P Rooms collection
    // 安全規則：只允許已登入的用戶（非匿名）建立房間
    match /p2pRooms/{roomId} {
      // 讀取：允許已登入用戶讀取公開房間，或讀取自己參與的房間
      allow read: if isAuthenticated() && (
        // 公開房間（isPrivate 不存在時視為公開）
        !('isPrivate' in resource.data) || !resource.data.isPrivate ||
        // 或參與者列表包含當前用戶
        request.auth.uid in resource.data.participants ||
        // 或是房主
        request.auth.uid == resource.data.ownerUid
      );

      // 建立：只允許已登入的用戶（非匿名）建立房間
      // 且 ownerUid 必須是當前用戶
      // 例外：若文件帶有 e2eTestMode=true 標記，允許匿名使用者建立（僅 emulator 環境有效）
      allow create: if isAuthenticated() &&
        request.resource.data.ownerUid == request.auth.uid &&
        participantsWithinCap(request.resource.data) &&
        (request.auth.token.firebase.sign_in_provider != "anonymous" ||
         request.resource.data.e2eTestMode == true);

      // 更新：允許房主更新房間，或使用者加入/更新自己的身分。
      // 任何更新都不得修改其他使用者的 meshIdentities 條目（防 MITM）。
      allow update: if isAuthenticated() && meshIdentitiesChangeIsValid() &&
        participantsWithinCap(request.resource.data) && (
        // 房主可以更新房間
        (request.auth.uid == resource.data.ownerUid) ||
        // 使用者加入房間：更新後必須在 participants 中，且房間非 closed
        (request.auth.uid in request.resource.data.participants &&
         resource.data.status != 'closed') ||
        // 既有參與者可以更新自己的 meshIdentity（含格式驗證）
        (request.auth.uid in resource.data.participants &&
         request.resource.data.meshIdentities != null &&
         request.resource.data.meshIdentities[request.auth.uid] != null &&
         isValidMeshIdentity(request.resource.data.meshIdentities[request.auth.uid]))
      );

      // 刪除：只允許房主刪除自己的房間
      allow delete: if isAuthenticated() &&
        request.auth.uid == resource.data.ownerUid;

      // Signals subcollection - signaling 訊息
      // 安全措施：
      //   1. 只能建立自己的 signal（from === auth.uid）
      //   2. payload 大小上限 10KB
      //   3. append-only（不可更新/刪除）
      //   4. 必須帶有 createdAt 時間戳
      //   5. createdAt 不得為未來時間（±30 秒容差）
      match /signals/{signalId} {
        // 只有該房間的參與者（或房主）能讀取 signaling — 防止任意登入用戶
        // 爬取所有房間的 ICE 候選 / SDP 來建立使用者圖譜。
        allow read: if isAuthenticated() && (
          request.auth.uid in get(/databases/$(database)/documents/p2pRooms/$(roomId)).data.participants ||
          request.auth.uid == get(/databases/$(database)/documents/p2pRooms/$(roomId)).data.ownerUid
        );
        allow create: if isAuthenticated()
          && request.resource.data.from == request.auth.uid
          && request.resource.data.type in ['offer', 'answer', 'ice']
          && request.resource.size() < 10 * 1024
          // createdAt 可為 number（客戶端 Date.now()）或 timestamp（serverTimestamp()）
          && (request.resource.data.createdAt is number || request.resource.data.createdAt is timestamp);
        allow update: if false;
        // 允許 signal 發送者刪除自己的 signal（連線建立後清理）
        // 或房間參與者刪除該房間的舊 signals（session cleanup）
        allow delete: if isAuthenticated()
          && resource.data.from == request.auth.uid;
      }

      // Messages subcollection - 備援聊天訊息（P2P 未連線時使用）
      // 允許參與者刪除（離開房間時清理個人訊息）
      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/p2pRooms/$(roomId)).data.participants;
        // 建立：必須是參與者、from 必須等於 auth.uid、且 createdAt 必須在
        // 30 秒內（防 replay）。createdAt 為 timestamp 或 number 皆可。
        allow create: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/p2pRooms/$(roomId)).data.participants &&
          request.resource.data.from == request.auth.uid &&
          (
            (request.resource.data.createdAt is timestamp &&
             request.resource.data.createdAt > request.time - duration.value(30, 's') &&
             request.resource.data.createdAt < request.time + duration.value(30, 's')) ||
            (request.resource.data.createdAt is number &&
             request.resource.data.createdAt > (request.time.toMillis() - 30000) &&
             request.resource.data.createdAt < (request.time.toMillis() + 30000))
          );
        allow update: if false;
        allow delete: if isAuthenticated()
          && resource.data.from == request.auth.uid;
      }
    }

    // 明確禁止其他集合儲存敏感內容
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
