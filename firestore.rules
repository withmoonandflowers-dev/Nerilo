rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      // 若尚未設定自訂角色（例如匿名使用者），預設視為 guest
      return request.auth.token.role != null ? request.auth.token.role : 'guest';
    }

    function isAdmin() {
      return getUserRole() == 'admin';
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // ── meshIdentities 驗證 ──────────────────────────────────────────────
    function isValidMeshIdentity(identity) {
      return identity.userId is string
        && identity.userId.size() >= 8
        && identity.userId.size() <= 64
        && identity.pubKey is string
        && identity.pubKey.size() >= 40
        && identity.pubKey.size() <= 512
        // ecdhPubKey 可選（ADR-0023 P2-②c keyx）；提供時驗格式。
        // 覆寫他人條目已由 meshIdentitiesChangeIsValid（affectedKeys ⊆ {auth.uid}）擋下。
        && (!('ecdhPubKey' in identity) || (
             identity.ecdhPubKey is string
             && identity.ecdhPubKey.size() >= 40
             && identity.ecdhPubKey.size() <= 512));
    }

    // 任何 update 都只能影響到 meshIdentities[auth.uid] 這個 key。
    // 沒有此檢查時，惡意參與者（甚至房主）可以覆寫他人的 ECDH 公鑰，造成 MITM。
    function meshIdentitiesChangeIsValid() {
      let oldMI = resource.data.get('meshIdentities', {});
      let newMI = request.resource.data.get('meshIdentities', {});
      // affectedKeys() 包含新增、修改、刪除的 key。要求 ⊆ {auth.uid}。
      return newMI.diff(oldMI).affectedKeys().hasOnly([request.auth.uid]);
    }

    // Features collection - 功能註冊表
    match /features/{featureId} {
      // 所有人可讀取 enabled=true 的功能
      allow read: if isAuthenticated();

      // 僅 admin 可寫入
      allow write: if isAdmin();
    }

    // Users collection - 使用者 profile
    // 開發階段簡化規則：只要有登入（包含匿名），即可讀寫自己的 users 文件
    match /users/{uid} {
      allow read, create, update: if isAuthenticated() && isOwner(uid);
      allow delete: if false; // 不允許從前端刪除 user 文件
    }

    // ── 房間人數上限（ADR-0005 第一層：結構性總量限制） ──────────────
    // 目前接線的拓撲上限是 5 人 full mesh；6 人以上的 partial mesh 未接線。
    // 方案分層上線後（ADR-0008），此上限改由 request.auth.token.plan 決定。
    function participantsWithinCap(data) {
      return data.participants is list
        && data.participants.size() <= 5;
    }

    // ── 參與者自行離開 ──────────────────────────────────────────────
    // leaveRoom 是把自己從 participants 移除，更新後 uid 必不在列表中，
    // 落不進「加入/更新身分」分支，需要獨立分支。
    // 限制：被移除的成員 ⊆ {自己} 且不得新增成員；只能動離開相關欄位；
    // meshIdentities 另受 meshIdentitiesChangeIsValid 限制（只能動自己的條目）。
    function isSelfLeaveOnly() {
      let oldP = resource.data.participants.toSet();
      let newP = request.resource.data.participants.toSet();
      return request.auth.uid in resource.data.participants
        && !(request.auth.uid in request.resource.data.participants)
        && oldP.difference(newP).hasOnly([request.auth.uid])
        && newP.difference(oldP).size() == 0
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(
             ['participants', 'participantCount', 'lastActiveAt', 'ttlExpireAt', 'meshIdentities']);
    }

    // P2P Rooms collection
    // 安全規則：只允許已登入的用戶（非匿名）建立房間
    match /p2pRooms/{roomId} {
      // 讀取：允許已登入用戶讀取公開房間，或讀取自己參與的房間
      allow read: if isAuthenticated() && (
        // 公開房間（isPrivate 不存在時視為公開）
        !('isPrivate' in resource.data) || !resource.data.isPrivate ||
        // 或參與者列表包含當前用戶
        request.auth.uid in resource.data.participants ||
        // 或是房主
        request.auth.uid == resource.data.ownerUid
      );

      // 建立：只允許已登入的用戶（非匿名）建立房間
      // 且 ownerUid 必須是當前用戶
      allow create: if isAuthenticated() &&
        request.resource.data.ownerUid == request.auth.uid &&
        participantsWithinCap(request.resource.data) &&
        request.auth.token.firebase.sign_in_provider != "anonymous";

      // 更新：允許房主更新房間，或使用者加入/更新自己的身分。
      // 任何更新都不得修改其他使用者的 meshIdentities 條目（防 MITM）。
      allow update: if isAuthenticated() && meshIdentitiesChangeIsValid() &&
        participantsWithinCap(request.resource.data) && (
        // 房主可以更新房間
        (request.auth.uid == resource.data.ownerUid) ||
        // 使用者加入房間：更新後必須在 participants 中，且房間非 closed
        (request.auth.uid in request.resource.data.participants &&
         resource.data.status != 'closed') ||
        // 參與者離開房間：把自己（且只有自己）從 participants 移除。
        // 必須排在 meshIdentity 分支之前：rules 的 || 由左至右短路且不吸收
        // 錯誤，後面分支若 evaluation error 會蓋掉這裡的 true。
        isSelfLeaveOnly() ||
        // 既有參與者可以更新自己的 meshIdentity（含格式驗證）。
        // 用 `in` 檢查 key 存在——直接索引不存在的 key 是 evaluation error。
        (request.auth.uid in resource.data.participants &&
         'meshIdentities' in request.resource.data &&
         request.auth.uid in request.resource.data.meshIdentities &&
         isValidMeshIdentity(request.resource.data.meshIdentities[request.auth.uid]))
      );

      // 刪除：房主，或任何參與者（持久聊天室的「全員軟刪除→最後一人真刪」
      // 路徑；成員互信模型下允許，見 RoomService.softDeleteRoom）
      allow delete: if isAuthenticated() && (
        request.auth.uid == resource.data.ownerUid ||
        request.auth.uid in resource.data.participants
      );

      // memberStates subcollection — 每位成員的個人狀態（已讀/釘選/軟刪除）
      // 文件 id = uid；只能寫自己的（防竄改他人已讀/刪除狀態），參與者可讀
      //（softDeleteRoom 需要讀全員狀態判斷是否全刪）。
      match /memberStates/{memberUid} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/p2pRooms/$(roomId)).data.participants;
        // 只能建立/更新自己的（防竄改他人已讀/釘選/刪除狀態）
        allow create, update: if isAuthenticated() &&
          request.auth.uid == memberUid &&
          request.auth.uid in get(/databases/$(database)/documents/p2pRooms/$(roomId)).data.participants;
        // 刪除開放給參與者：全員軟刪除後的真刪除要連他人狀態文件一起清，
        // 否則留孤兒子文件（父文件刪除不會級聯）
        allow delete: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/p2pRooms/$(roomId)).data.participants;
      }

      // Signals subcollection - signaling 訊息
      // 安全措施：
      //   1. 只能建立自己的 signal（from === auth.uid）
      //   2. payload 大小上限 10KB
      //   3. append-only（不可更新/刪除）
      //   4. 必須帶有 createdAt 時間戳
      //   5. createdAt 不得為未來時間（±30 秒容差）
      match /signals/{signalId} {
        // 只有該房間的參與者（或房主）能讀取 signaling — 防止任意登入用戶
        // 爬取所有房間的 ICE 候選 / SDP 來建立使用者圖譜。
        allow read: if isAuthenticated() && (
          request.auth.uid in get(/databases/$(database)/documents/p2pRooms/$(roomId)).data.participants ||
          request.auth.uid == get(/databases/$(database)/documents/p2pRooms/$(roomId)).data.ownerUid
        );
        allow create: if isAuthenticated()
          && request.resource.data.from == request.auth.uid
          && request.resource.data.type in ['offer', 'answer', 'ice']
          && request.resource.size() < 10 * 1024
          // createdAt 可為 number（客戶端 Date.now()）或 timestamp（serverTimestamp()）
          && (request.resource.data.createdAt is number || request.resource.data.createdAt is timestamp);
        allow update: if false;
        // 允許 signal 發送者刪除自己的 signal（連線建立後清理）
        // 或房間參與者刪除該房間的舊 signals（session cleanup）
        allow delete: if isAuthenticated()
          && resource.data.from == request.auth.uid;
      }

      // Messages subcollection - 備援聊天訊息（P2P 未連線時使用）
      // 允許參與者刪除（離開房間時清理個人訊息）
      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/p2pRooms/$(roomId)).data.participants;
        // 建立：必須是參與者、from 必須等於 auth.uid、且 createdAt 必須在
        // 30 秒內（防 replay）。createdAt 為 timestamp 或 number 皆可。
        allow create: if isAuthenticated() &&
          request.auth.uid in get(/databases/$(database)/documents/p2pRooms/$(roomId)).data.participants &&
          request.resource.data.from == request.auth.uid &&
          (
            (request.resource.data.createdAt is timestamp &&
             request.resource.data.createdAt > request.time - duration.value(30, 's') &&
             request.resource.data.createdAt < request.time + duration.value(30, 's')) ||
            (request.resource.data.createdAt is number &&
             request.resource.data.createdAt > (request.time.toMillis() - 30000) &&
             request.resource.data.createdAt < (request.time.toMillis() + 30000))
          );
        allow update: if false;
        allow delete: if isAuthenticated()
          && resource.data.from == request.auth.uid;
      }
    }

    // 好友關係（2026-07-05）：id = 排序後 uidA_uidB；只有當事雙方可讀寫。
    // 只有「受邀方」能把 pending 改 accepted（防單方面自我通過）。
    match /friendships/{fid} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.uids;
      allow create: if isAuthenticated() &&
        request.resource.data.uids.size() == 2 &&
        request.auth.uid in request.resource.data.uids &&
        request.resource.data.requestedBy == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update: if isAuthenticated() &&
        request.auth.uid in resource.data.uids &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'accepted' &&
        resource.data.requestedBy != request.auth.uid;
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.uids;
    }

    // 全站節點名冊（ADR-0023 P4-A）：線上節點宣告可中繼/當盲信使，供陌生節點
    // 互相發現、建立站級 overlay。id = 宣告者的 auth.uid（一使用者/裝置一則）。
    // 隱私：宣告只含 nodeId + 粗略 metrics + regionHint，不含 IP。
    match /relayDirectory/{ownerUid} {
      // 讀：任何登入者可查名冊（發現候選節點）。
      allow read: if isAuthenticated();
      // 寫：只能寫自己那一則（防冒名/覆寫他人宣告 → 反女巫、防名冊污染）；非匿名才可
      // 宣告；announcedAt 需在 server 時間 ±60s（防灌陳舊/未來宣告佔位）；nodeId 格式限制。
      allow create, update: if isAuthenticated()
        && ownerUid == request.auth.uid
        && request.resource.data.ownerUid == request.auth.uid
        && request.auth.token.firebase.sign_in_provider != 'anonymous'
        && request.resource.data.nodeId is string
        && request.resource.data.nodeId.size() >= 8
        && request.resource.data.nodeId.size() <= 64
        && request.resource.data.announcedAt is number
        && request.resource.data.announcedAt > request.time.toMillis() - 60000
        && request.resource.data.announcedAt < request.time.toMillis() + 60000
        && request.resource.size() < 4 * 1024;
      // 撤回：只能撤自己。
      allow delete: if isAuthenticated() && ownerUid == request.auth.uid;
    }

    // 陌生節點站級 signaling（ADR-0023 P4-B）：非成員與成員在不綁房的 pairwise
    // 通道上交換 WebRTC signals，建 relay-only DataChannel（盲信使補齊的傳輸）。
    // channelId = 雙方 uid 排序後串接。只有通道 participants 內兩人能讀寫。
    match /relaySignals/{channelId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      // 開通道：必須是雙方之一、participants 恰好 2 人、非匿名（反女巫）。
      allow create: if isAuthenticated()
        && request.resource.data.participants is list
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
      // 更新（ensureChannel merge 續期）：participants 不得變更。
      allow update: if isAuthenticated()
        && request.auth.uid in resource.data.participants
        && request.resource.data.participants == resource.data.participants;
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.participants;

      // signals 子集合：append-only 的 offer/answer/ice。
      match /signals/{signalId} {
        function chanParticipants() {
          return get(/databases/$(database)/documents/relaySignals/$(channelId)).data.participants;
        }
        allow read: if isAuthenticated() && request.auth.uid in chanParticipants();
        allow create: if isAuthenticated()
          && request.auth.uid in chanParticipants()
          && request.resource.data.from == request.auth.uid
          && request.resource.data.type in ['offer', 'answer', 'ice']
          && request.resource.size() < 10 * 1024
          && (request.resource.data.createdAt is number || request.resource.data.createdAt is timestamp);
        allow update: if false; // append-only
        allow delete: if isAuthenticated() && resource.data.from == request.auth.uid;
      }
    }

    // 明確禁止其他集合儲存敏感內容
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
