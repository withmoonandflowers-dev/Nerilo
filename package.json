{
  "name": "nerilo",
  "version": "1.0.0",
  "description": "Firebase + WebRTC P2P 即時互動平台",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:test": "vite --port 4173 --strictPort --mode test",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:emulator": "firebase emulators:exec --only auth,firestore 'npm run test:integration'",
    "test:all": "npm run test:run && npm run test:integration",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "deploy": "npm run build && firebase deploy --only hosting",
    "deploy:hosting": "npm run build && firebase deploy --only hosting",
    "deploy:full": "npm run build && firebase deploy",
    "deploy:safe": "npm run type-check && npm run lint && npm run test:run && npm run deploy",
    "ci": "npm run type-check && npm run lint && npm run test:run",
    "ci:full": "npm run type-check && npm run lint && npm run test:emulator",
    "ci:fast": "npm run type-check && npm run test:run",
    "check": "npm run ci"
  },
  "dependencies": {
    "dexie": "^3.2.4",
    "firebase": "^10.7.1",
    "firebase-admin": "^13.6.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3",
    "uuid": "^9.0.1"
  },
  "optionalDependencies": {
    "@esbuild/darwin-arm64": "0.21.5",
    "@esbuild/darwin-x64": "0.21.5",
    "@esbuild/linux-x64": "0.27.2",
    "@rollup/rollup-darwin-arm64": "4.55.1",
    "@rollup/rollup-darwin-x64": "4.55.1",
    "@rollup/rollup-linux-x64-gnu": "4.55.1",
    "@rollup/rollup-linux-x64-musl": "4.55.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jsdom": "^27.4.0",
    "rollup": "^4.24.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vitest": "^4.0.18"
  }
}
